/**
 * 根据日期获取每日知识（同一天返回同一条，不同天随机不同）
 * @param date 可选参数，默认当天
 * @returns KnowledgeItem
 */
export function getDailyKnowledge(date?: Date): KnowledgeItem {
  const targetDate = date || new Date();
  // 使用年月日作为种子，确保同一天返回同一条
  const seed = targetDate.getFullYear() * 10000 + (targetDate.getMonth() + 1) * 100 + targetDate.getDate();
  // 简单哈希取模
  const index = (seed * 2654435761) % KNOWLEDGE_LIST.length >>> 0;
  return KNOWLEDGE_LIST[index];
}

/**
 * 完全随机获取一条知识（每次调用结果不同）
 * @returns KnowledgeItem
 */
export function getRandomKnowledge(): KnowledgeItem {
  const index = Math.floor(Math.random() * KNOWLEDGE_LIST.length);
  return KNOWLEDGE_LIST[index];
}
